# Maintenance mode — set to "true" to redirect all traffic to /maintenance
MAINTENANCE_MODE=false
# Dominio(s) donde se aplica el bloqueo (separados por coma si hay varios).
# Déjalo vacío para bloquear en TODOS los dominios (incluido *.vercel.app).
# Ejemplo: MAINTENANCE_DOMAIN=yourdomain.com
MAINTENANCE_DOMAIN=
NEXT_PUBLIC_APP_URL=https://gimo-web.vercel.app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STANDARD_PRICE_ID=price_...

# Firebase Admin (server-side, JSON service account key as single line/base64)
FIREBASE_ADMIN_SERVICE_ACCOUNT=
ADMIN_EMAILS=admin@gimo.ai

# Internal auth shared secret for orchestrator -> gimo-web internal endpoints
GIMO_INTERNAL_KEY=

# License signing key (Ed25519 PKCS8 private key, newlines as \n)
LICENSE_SIGNING_PRIVATE_KEY=
